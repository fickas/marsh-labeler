# Copy to .env for local dev (it is gitignored).
DATABASE_URL=postgresql+psycopg://marsh:marsh@localhost:5432/marsh

# Chip storage: "local" (dev) writes PNGs to a folder; "s3" uploads to R2/S3.
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./_chips
CHIP_BASE_URL=/chips

# For S3/R2 (set STORAGE_BACKEND=s3):
# STORAGE_S3_BUCKET=marsh-chips
# STORAGE_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_S3_ACCESS_KEY=...
# STORAGE_S3_SECRET_KEY=...
